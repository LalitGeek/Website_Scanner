# Server configuration
PORT=3000
NODE_ENV=development

# Redis configuration
# For Docker Compose, use: redis://redis:6379
# For local fallback, use: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# AES-256-GCM Encryption Key (Must be 32 bytes / 64 hex characters)
# Generate a new one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=d4a2d8a57e3c150b0f4ef51336cde89bf718e24fa2b4cd6fa2bdfa67b1ef8a3c

# Gemini API configuration
GEMINI_API_KEY=


# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

