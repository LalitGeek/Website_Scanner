{
  "manifest_version": 3,
  "name": "Scanify - Technology Profiler",
  "version": "1.2.0",
  "description": "Analyze websites for security, technology, SEO, and performance insights.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/scripts/techSignatures.js",
        "src/scripts/content.js"
      ]
    }
  ]
}